        </mxCell>
        <mxCell id="lane-record-label" value="Step 5 — Save &amp; Record" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#4c2c7d;" vertex="1" parent="1">
