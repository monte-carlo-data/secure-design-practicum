        <!-- loop yes → back to triage -->
        <mxCell id="e2-loop-yes" value="Y" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0;exitY=0.5;entryX=0.5;entryY=0;strokeColor=#1e4d78;fontColor=#1e4d78;fontStyle=1;" edge="1" source="loop-ask" target="triage-queue" parent="1">
