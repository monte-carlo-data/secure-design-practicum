        </mxCell>

        <mxCell id="record-tracking" value="Part B — Update TRACKING.md&#xa;(show diff, user confirms)&#xa;&#xa;Set: Status → Reviewed&#xa;Fill: Risk Rating, Sec Relevant,&#xa;Reviewer, Date, Ticket, File" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="935" y="290" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="record-contrast" value="vs. pipeline PR:&#xa;pipeline writes In Progress row.&#xa;Skill writes Reviewed row&#xa;after Security signs off." style="shape=note;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="935" y="440" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- STEP 6 — NOTIFY                                               -->
        <!-- ============================================================ -->
        <mxCell id="decision-involvement2" value="Involvement level?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1180" y="140" width="180" height="70" as="geometry" />
        </mxCell>

        <mxCell id="notify2-ask" value="Ask: Slack? Linear? Both? Skip?&#xa;&#xa;[S] Security channel&#xa;[L] Linear triage (Required only)&#xa;[B] Both&#xa;[N] Skip" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1175" y="245" width="200" height="100" as="geometry" />
        </mxCell>

        <mxCell id="notify2-slack" value="Post to security channel&#xa;(Slack MCP)&#xa;Red = Required&#xa;Yellow = Recommended" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1175" y="375" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="notify2-linear" value="Create Linear triage ticket&#xa;(Linear MCP, Required only)&#xa;Security team, unassigned&#xa;→ update TRACKING.md&#xa;   with ticket URL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
