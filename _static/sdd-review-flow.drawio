        <mxCell id="lane-ctx-label" value="Step 1 — Load Context" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#2d6a28;" vertex="1" parent="1">
