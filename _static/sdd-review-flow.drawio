        <mxCell id="cmp-flow" value="How they connect: Pipeline runs first (engineering self-service) → sets TRACKING.md to In Progress → /sdd-review skill picks it up → Security does deeper review → sets status to Reviewed" style="text;html=1;strokeColor=none;fillColor=#fff9e6;strokeColor=#d6b656;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="950" width="570" height="40" as="geometry" />
