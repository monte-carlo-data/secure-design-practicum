        <mxCell id="ctx-tracking" value="Read TRACKING.md&#xa;(parse all SDD rows,&#xa;status, reviewer, etc.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="215" y="140" width="190" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ctx-platform" value="Read platform_context.md&#xa;(tenant scoping, identity gateway,&#xa;queueing, IAM patterns,&#xa;existing controls)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="215" y="220" width="190" height="70" as="geometry" />
        </mxCell>

        <mxCell id="ctx-guides" value="Read review guides:&#xa;• Quick Security Review&#xa;• Architecture Walkthrough Qs&#xa;• Self-Service Checklist" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="215" y="310" width="190" height="80" as="geometry" />
        </mxCell>

        <mxCell id="ctx-note" value="All context held in memory&#xa;for the full session" style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="215" y="410" width="190" height="40" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- STEP 2 — TRIAGE QUEUE                                         -->
        <!-- ============================================================ -->
        <mxCell id="triage-queue" value="Show pending queue:&#xa;&#xa;[1] In Progress (resume first)&#xa;[2] Security-Relevant (Yes)&#xa;[3] Other Pending" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="435" y="140" width="190" height="100" as="geometry" />
        </mxCell>

        <mxCell id="triage-pick" value="User selects SDD&#xa;(by number, name,&#xa;or pastes Notion URL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="435" y="270" width="190" height="60" as="geometry" />
        </mxCell>

        <mxCell id="triage-notfound" value="SDD not in tracking?&#xa;→ offer to add as Pending&#xa;before continuing" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="435" y="360" width="190" height="50" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- STEP 3 — FETCH SDD                                            -->
        <!-- ============================================================ -->
        <mxCell id="fetch-notion" value="Fetch SDD from Notion&#xa;(Notion MCP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="655" y="140" width="240" height="50" as="geometry" />
        </mxCell>

        <mxCell id="fetch-fail" value="Fetch fails?&#xa;→ paste content or skip" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="675" y="215" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- STEP 4 — ANALYZE                                              -->
        <!-- ============================================================ -->
        <mxCell id="analyze-score" value="Part A — Involvement scoring&#xa;Likelihood × Impact (1–25)&#xa;→ Required / Recommended /&#xa;   Not Required" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="655" y="305" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="analyze-lens1" value="Part B — Lens 1&#xa;Quick Security Review&#xa;Answer all 10 &quot;Security Steve&quot;&#xa;questions from SDD content" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="655" y="405" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="analyze-lens2" value="Part B — Lens 2&#xa;Architecture Walkthrough&#xa;10 domains: auth, authz,&#xa;data flow, secrets, integrations,&#xa;logging, IR, compliance, …" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="655" y="505" width="240" height="90" as="geometry" />
        </mxCell>

        <mxCell id="analyze-lens3" value="Part B — Lens 3&#xa;Self-Service Checklist&#xa;7 categories, flag priority areas&#xa;with multiple gaps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="655" y="615" width="240" height="70" as="geometry" />
        </mxCell>

        <mxCell id="analyze-platform-note" value="Platform context applied throughout:&#xa;tenant scoping, gateway auth,&#xa;queue isolation, secrets mgmt" style="shape=note;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="655" y="703" width="240" height="50" as="geometry" />
        </mxCell>

        <mxCell id="analyze-output" value="Part C — Synthesize:&#xa;• 3–8 security questions (gap-grounded)&#xa;• Data classification table&#xa;• Gaps summary&#xa;→ User confirms / adjusts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="655" y="773" width="240" height="90" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- STEP 5 — SAVE & RECORD                                        -->
        <!-- ============================================================ -->
        <mxCell id="record-reviewmd" value="Part A — Write review.md?&#xa;(optional, user confirms)&#xa;&#xa;reviews/&lt;slug&gt;/review.md&#xa;Contains: involvement, questions,&#xa;data classification, gaps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
