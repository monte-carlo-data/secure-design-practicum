        <!-- ============================================================ -->
        <mxCell id="invoke-skill" value="/sdd-review&#xa;in Claude Code" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="140" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- Contrast note vs pipeline -->
        <mxCell id="invoke-contrast" value="vs. GitHub Action:&#xa;runs in your local&#xa;Claude Code session,&#xa;not CI/CD" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=10;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="30" y="220" width="160" height="70" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
