        </mxCell>
        <mxCell id="lane-loop-label" value="Step 7 — Loop" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#4a1a8a;" vertex="1" parent="1">
