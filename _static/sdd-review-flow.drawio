        </mxCell>
        <mxCell id="lane-analyze-label" value="Steps 3–4 — Fetch &amp; Analyze" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#8a4a00;" vertex="1" parent="1">
          <mxGeometry x="640" y="80" width="280" height="30" as="geometry" />
